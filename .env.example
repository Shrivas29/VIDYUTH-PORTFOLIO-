# Copy to .env.local for local dev, and set these in Vercel → Project → Settings
# → Environment Variables for production. All are optional; sensible fallbacks
# apply when unset.

# Canonical site origin. Drives OG/canonical URLs, the sitemap, robots, and
# JSON-LD. Set to the www host, since the apex redirects to www.
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.vidyuthracing.co.in

# Plausible analytics domain. When set, the privacy-friendly Plausible script
# loads and reports under this domain. Leave unset to ship with no analytics.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=vidyuthracing.co.in

# Google Search Console verification token (the value from the "HTML tag"
# method, without the surrounding meta markup). Only needed if you verify via
# the HTML tag instead of the DNS TXT record. Leave unset otherwise.
# GOOGLE_SITE_VERIFICATION=
